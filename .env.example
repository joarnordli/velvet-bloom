# Template — committed to git. Copy to .env for local dev and fill in there.
# NEVER put real secrets in this file. All values are SERVER-side (no VITE_ vars).

# Self-hosted Postgres (Coolify VPS). Use Coolify's INTERNAL connection string
# in production; a public/tunnelled one only for local migrate/studio.
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DBNAME"

# Better Auth — generate a strong secret: `openssl rand -base64 32`.
# BETTER_AUTH_URL is the app's public origin, no trailing slash.
# Local dev: http://localhost:8080 — Production: https://your-domain (https!).
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:8080"

# Cloudflare R2 (S3-compatible) object storage for avatars / post / message media.
# Create a private bucket + an R2 API token (Object Read & Write).
# R2_ENDPOINT = https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="mittpunkt-media"
R2_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
